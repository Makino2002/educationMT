.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# turbo
.turbo

# cache
.cache/
.eslintcache

# typescript
*.tsbuildinfo
next-env.d.ts

# coverage
/coverage

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# local database
*.db
*.sqlite

# uploads
/uploads

# temp
*.tmp
*.temp
